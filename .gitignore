# === DEPENDENCIES ===
# Dependencies should never be committed to version control
node_modules/
.pnp
.pnp.*
.yarn/

# === BUILD ARTIFACTS ===
# Compiled output and build metadata
.next/
out/
build/
dist/
*.tsbuildinfo

# === ENVIRONMENT & SECRETS ===
# Local environment variables containing secrets
.env
.env.*
.env.local
.env.*.local
# Security credentials and keys
*.pem
*.key
secrets.*

# === OS & EDITOR JUNK ===
# System specific files
.DS_Store
Thumbs.db
# Editor specific configurations
.vscode/
.idea/
*.swp
*.swo

# === LOGS & TEMPORARY FILES ===
# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
*.log
# Test coverage artifacts
coverage/

# === PROJECT-SPECIFIC ===
# Auto-generated Next.js types
next-env.d.ts
# Vercel deployment metadata
.vercel
